<%- include('partials/header') %>
<section class="list-page">
  <div class="section-head">
    <h1>Blog</h1>
    <a class="btn-solid" href="/blog/new">Write a post</a>
  </div>
  <div class="blog-card-grid">
    <% posts.forEach(function(post) { %>
      <a class="blog-card" href="/blog/<%= post.slug %>">
        <% if (post.cover_image) { %><img src="<%= post.cover_image %>" alt=""><% } %>
        <div class="blog-card-body">
          <h3><%= post.title %></h3>
          <span class="meta">by <%= post.author_name %> &middot; <%= new Date(post.created_at).toLocaleDateString() %></span>
        </div>
      </a>
    <% }) %>
    <% if (posts.length === 0) { %><p class="empty">No posts yet. Be the first to write one!</p><% } %>
  </div>
</section>
<%- include('partials/footer') %>
