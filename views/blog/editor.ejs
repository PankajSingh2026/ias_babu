<%- include('partials/header') %>
<section class="editor-page">
  <h1>Write a Blog Post</h1>
  <p class="hint">Your post will be reviewed by an admin before it appears publicly, unless you're an admin.</p>
  <% if (errors.length) { %>
    <ul class="form-error"><% errors.forEach(function(e){ %><li><%= e %></li><% }) %></ul>
  <% } %>
  <form method="POST" action="/blog/new" class="form" id="blog-form">
    <label>Title<input type="text" name="title" required></label>
    <label>Cover image URL (optional)<input type="text" name="cover_image" placeholder="https://..."></label>
    <label>Content</label>
    <div id="editor"></div>
    <textarea name="content_html" id="content_html" style="display:none"></textarea>
    <button class="btn-solid" type="submit">Submit Post</button>
  </form>
</section>

<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
  let editorInstance;
  ClassicEditor.create(document.querySelector('#editor'), {
    simpleUpload: { uploadUrl: '/blog/upload-image' }
  }).then(editor => {
    editorInstance = editor;
  });
  document.getElementById('blog-form').addEventListener('submit', function () {
    document.getElementById('content_html').value = editorInstance.getData();
  });
</script>
<%- include('partials/footer') %>
