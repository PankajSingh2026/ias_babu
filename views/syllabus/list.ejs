<%- include('partials/header') %>
<section class="list-page">
  <h1>Syllabus</h1>
  <ul class="full-list">
    <% pages.forEach(function(p) { %>
      <li><a href="/syllabus/<%= p.slug %>"><%= p.title %></a></li>
    <% }) %>
    <% if (pages.length === 0) { %><li class="empty">No syllabus pages published yet.</li><% } %>
  </ul>
</section>
<%- include('partials/footer') %>
