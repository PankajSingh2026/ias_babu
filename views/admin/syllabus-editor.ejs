<%- include('../partials/admin-header') %>
<h1><%= page ? 'Edit' : 'New' %> Syllabus Page</h1>
<p class="hint">Type the syllabus like a Word document. To add a book purchase link, type the text, select it, click the Link icon in the toolbar, and paste the book's purchase URL.</p>

<form method="POST" action="<%= page ? `/admin/syllabus/${page.id}/edit` : '/admin/syllabus/new' %>" class="form" id="syllabus-form">
  <label>Title<input type="text" name="title" value="<%= page ? page.title : '' %>" required></label>
  <label class="checkbox-label"><input type="checkbox" name="is_published" <%= (!page || page.is_published) ? 'checked' : '' %>> Published</label>
  <label>Content</label>
  <div id="editor"><%- page ? page.content_html : '' %></div>
  <textarea name="content_html" id="content_html" style="display:none"></textarea>
  <button class="btn-solid" type="submit">Save</button>
</form>

<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
  let editorInstance;
  ClassicEditor.create(document.querySelector('#editor'), {
    simpleUpload: { uploadUrl: '/admin/upload-image' },
    table: { contentToolbar: ['tableColumn', 'tableRow', 'mergeTableCells'] }
  }).then(editor => { editorInstance = editor; });
  document.getElementById('syllabus-form').addEventListener('submit', function () {
    document.getElementById('content_html').value = editorInstance.getData();
  });
</script>
<%- include('../partials/admin-footer') %>
