<%- include('../partials/admin-header') %>
<h1>Navigation Bar</h1>

<table class="admin-table">
  <thead><tr><th>Order</th><th>Label</th><th>URL</th><th>Visible</th><th>Actions</th></tr></thead>
  <tbody>
    <% links.forEach(function(l) { %>
      <tr>
        <form method="POST" action="/admin/nav/<%= l.id %>/update">
          <td><input type="number" name="sort_order" value="<%= l.sort_order %>" style="width:60px"></td>
          <td><input type="text" name="label" value="<%= l.label %>"></td>
          <td><input type="text" name="url" value="<%= l.url %>"></td>
          <td><input type="checkbox" name="is_visible" <%= l.is_visible ? 'checked' : '' %>></td>
          <td>
            <button class="btn-small" type="submit">Save</button>
        </form>
        <form method="POST" action="/admin/nav/<%= l.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this nav link?')">
            <button class="btn-small danger" type="submit">Delete</button>
        </form>
          </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<h2>Add Nav Link</h2>
<form method="POST" action="/admin/nav" class="form inline-form">
  <input type="text" name="label" placeholder="Label" required>
  <input type="text" name="url" placeholder="/path or https://..." required>
  <input type="number" name="sort_order" placeholder="Order" value="0" style="width:80px">
  <button class="btn-solid" type="submit">Add</button>
</form>
<%- include('../partials/admin-footer') %>
