<%- include('../partials/admin-header') %>
<h1>Site Pages</h1>
<% pages.forEach(function(p) { %>
  <details class="page-block" open>
    <summary><%= p.page_key %></summary>
    <form method="POST" action="/admin/pages/<%= p.page_key %>" class="form page-form">
      <label>Title<input type="text" name="title" value="<%= p.title || '' %>"></label>
      <label>Content</label>
      <div class="editor-target" id="editor-<%= p.page_key %>"><%- p.content_html || '' %></div>
      <textarea name="content_html" id="content_html-<%= p.page_key %>" style="display:none"></textarea>
      <button class="btn-solid" type="submit">Save</button>
    </form>
  </details>
<% }) %>

<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script>
  document.querySelectorAll('.editor-target').forEach(function (el) {
    ClassicEditor.create(el, { simpleUpload: { uploadUrl: '/admin/upload-image' } }).then(function (editor) {
      el.closest('form').addEventListener('submit', function () {
        document.getElementById('content_html-' + el.id.replace('editor-', '')).value = editor.getData();
      });
    });
  });
</script>
<%- include('../partials/admin-footer') %>
