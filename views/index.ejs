<%- include('partials/header') %>

<section class="hero">
  <%- homeIntro ? homeIntro.content_html : '' %>
</section>
<section class="notif-grid">
  <%- include('partials/notification-widget', { heading: 'Latest Jobs', items: jobs, viewAllUrl: '/latest-jobs' }) %>
  <%- include('partials/notification-widget', { heading: 'Admit Card', items: admitCards, viewAllUrl: '/admit-card' }) %>
  <%- include('partials/notification-widget', { heading: 'Result', items: results, viewAllUrl: '/result' }) %>
</section>

<section class="home-blog">
  <div class="section-head">
    <h2>From the Blog</h2>
    <a href="/blog">View all posts &rarr;</a>
  </div>
  <div class="blog-card-grid">
    <% latestBlogs.forEach(function(post) { %>
      <a class="blog-card" href="/blog/<%= post.slug %>">
        <% if (post.cover_image) { %><img src="<%= post.cover_image %>" alt=""><% } %>
        <div class="blog-card-body">
          <h3><%= post.title %></h3>
          <span class="meta">by <%= post.author_name %></span>
        </div>
      </a>
    <% }) %>
    <% if (latestBlogs.length === 0) { %>
      <p class="empty">No blog posts published yet.</p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
